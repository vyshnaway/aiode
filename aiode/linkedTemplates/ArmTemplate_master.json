{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "aiode"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"AzureDatabricksDeltaLake1_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'AzureDatabricksDeltaLake1'"
		},
		"AzureSqlDatabase1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase1'"
		},
		"AzureSqlDatabase_HospitalA_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase_HospitalA'"
		},
		"AzureSqlDatabase_HospitalB_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase_HospitalB'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://aiode.dfs.core.windows.net/"
		},
		"AzureKeyVault1_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://aiode.vault.azure.net/"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "aiode.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().db_name}"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "aiode"
		},
		"AzureSqlDatabase_HospitalA_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "aiode.database.windows.net"
		},
		"AzureSqlDatabase_HospitalA_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "hospital-a"
		},
		"AzureSqlDatabase_HospitalA_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "aiode"
		},
		"AzureSqlDatabase_HospitalB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "aiode.database.windows.net"
		},
		"AzureSqlDatabase_HospitalB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "hospital-b"
		},
		"AzureSqlDatabase_HospitalB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "aiode"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "aiode_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"AzureDatabricksDeltaLake1_accessToken": {
						"value": "[parameters('AzureDatabricksDeltaLake1_accessToken')]"
					},
					"AzureSqlDatabase1_password": {
						"value": "[parameters('AzureSqlDatabase1_password')]"
					},
					"AzureSqlDatabase_HospitalA_password": {
						"value": "[parameters('AzureSqlDatabase_HospitalA_password')]"
					},
					"AzureSqlDatabase_HospitalB_password": {
						"value": "[parameters('AzureSqlDatabase_HospitalB_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureKeyVault1_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault1_properties_typeProperties_baseUrl')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
					},
					"AzureSqlDatabase_HospitalA_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_HospitalA_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_HospitalA_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_HospitalA_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_HospitalA_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_HospitalA_properties_typeProperties_userName')]"
					},
					"AzureSqlDatabase_HospitalB_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_HospitalB_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_HospitalB_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_HospitalB_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_HospitalB_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_HospitalB_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}